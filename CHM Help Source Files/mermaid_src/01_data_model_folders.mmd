graph TD
    classDef folder fill:#2c5f8a,color:#fff,stroke:#1a3d5c,font-weight:bold
    classDef file fill:#f5f5f5,color:#333,stroke:#999
    classDef pkg fill:#e8f4e8,color:#2c6b2c,stroke:#5cb85c

    DB["📁 db/<br/><i>Application Data (read-only)</i>"]:::folder
    S1["📄 settings.json<br/><small>Application settings</small>"]:::file
    S2["📄 system_libraries.json<br/><small>Hamilton system library definitions</small>"]:::file
    S3["📄 system_library_hashes.json<br/><small>Integrity baseline for system libraries</small>"]:::file

    LOCAL["📁 local/<br/><i>User Data Directory</i>"]:::folder
    L1["📄 installed_libs.json<br/><small>Installed library records</small>"]:::file
    L2["📄 groups.json<br/><small>Custom navigation groups</small>"]:::file
    L3["📄 tree.json<br/><small>Group ↔ library assignments</small>"]:::file
    L4["📄 unsigned_libs.json<br/><small>Auto-detected unsigned libraries</small>"]:::file
    L5["📄 audit_trail.json<br/><small>Event history</small>"]:::file
    L6["📄 publisher_registry.json<br/><small>Known authors and tags</small>"]:::file
    LP["📁 packages/<br/><i>Cached .hxlibpkg files</i>"]:::folder

    M1["📁 MyLibrary/"]:::folder
    M1F["📦 MyLibrary_v1.0.0_20260115-103000.hxlibpkg"]:::pkg
    A1["📁 AnotherLib/"]:::folder
